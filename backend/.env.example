# Copia este fichero como .env y rellena los valores
# El .env real NO se sube al repositorio

# Django
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-segura
DJANGO_DEBUG=true

# Google Earth Engine (necesario para extracción de telemetría)
EE_SERVICE_ACCOUNT=tu-cuenta@tu-proyecto.iam.gserviceaccount.com
EE_PRIVATE_KEY_FILE=/ruta/absoluta/al/fichero-credenciales.json
EE_PROJECT=tu-proyecto-gee

